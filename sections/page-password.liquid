{%- comment -%}
  Página de Contraseña / Próximamente — WF Urban Muscle
  Split-screen idéntico al login. Sin header ni footer (layout/password.liquid).
  Subir a: sections/password.liquid
{%- endcomment -%}

<div class="wf-split-screen wf-password-screen">

  {%- comment -%} PANEL IZQUIERDO: IMAGEN DE MARCA {%- endcomment -%}
  <div class="wf-split-image-panel">
    <div class="wf-split-overlay"></div>

    {%- if section.settings.bg_image != blank -%}
      <img src="{{ section.settings.bg_image | img_url: '1500x' }}" alt="{{ shop.name }}">
    {%- else -%}
      <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=1470&auto=format&fit=crop" alt="{{ shop.name }}">
    {%- endif -%}

    <div class="wf-split-brand-text">
      <h2>{{ section.settings.brand_title | default: shop.name }}</h2>
      <p>{{ section.settings.brand_subtitle | default: 'Algo grande está por llegar.' }}</p>
    </div>
  </div>

  {%- comment -%} PANEL DERECHO: FORMULARIOS {%- endcomment -%}
  <div class="wf-split-form-panel">
    <div class="wf-form-container">

      {%- comment -%} Logo {%- endcomment -%}
      <div class="wf-password__logo">
        {%- if settings.logo_use_image -%}
          <img src="{{ 'logo-white.png' | asset_url }}" alt="{{ shop.name }}" width="{{ settings.logo_max_width | default: 140 }}">
        {%- else -%}
          <span class="wf-password__logo-text">{{ shop.name | upcase }}</span>
        {%- endif -%}
      </div>

      {%- comment -%} Encabezado {%- endcomment -%}
      <div class="wf-form-header wf-password__header">
        <span class="wf-password__label">{{ section.settings.label | default: 'Próximamente' }}</span>
        <h1 class="page-title">{{ section.settings.title | default: 'Estamos preparando algo increíble' }}</h1>
        <p>{{ section.settings.subtitle | default: 'Vuelve pronto. Mientras tanto, déjanos tu email para ser el primero en enterarte.' }}</p>
      </div>

      {%- comment -%} Newsletter / Waitlist {%- endcomment -%}
      {%- assign news_id = 'pwd-newsletter-' | append: section.id -%}
      {%- form 'customer', id: news_id, class: 'wf-password__newsletter' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,waitlist">
        {{ form.errors | default_errors }}
        {%- if form.posted_successfully? -%}
          <p class="wf-password__success">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            ¡Listo! Te avisamos en cuanto abramos.
          </p>
        {%- else -%}
          <div class="wf-input-group">
            <label for="PwdEmail">{{ section.settings.email_label | default: 'Tu correo electrónico' }}</label>
            <input type="email" name="contact[email]" id="PwdEmail"
                   placeholder="tu@correo.com"
                   autocorrect="off" autocapitalize="off"
                   value="{% if customer %}{{ customer.email }}{% endif %}">
          </div>
          <div class="wf-form-actions">
            <button type="submit" class="wf-btn-primary">
              {{ section.settings.cta_text | default: 'Avísame cuando abran' }}
            </button>
          </div>
        {%- endif -%}
      {%- endform -%}

      {%- comment -%} Divisor {%- endcomment -%}
      <div class="wf-password__divider">
        <span>o accede con contraseña</span>
      </div>

      {%- comment -%} Formulario de contraseña de tienda {%- endcomment -%}
      {%- form 'storefront_password', class: 'wf-password__form' -%}
        {{ form.errors | default_errors }}
        <div class="wf-input-group">
          <label for="Password">Contraseña de acceso</label>
          <input type="password" name="password" id="Password"
                 placeholder="••••••••"
                 class="{% if form.errors contains 'password' %}error{% endif %}">
        </div>
        <div class="wf-form-actions">
          <button type="submit" class="wf-btn-secondary">Entrar →</button>
        </div>
      {%- endform -%}

      {%- comment -%} Redes sociales {%- endcomment -%}
      {%- assign has_social = false -%}
      {%- if settings.social_instagram_link != blank or settings.social_tiktok_link != blank or settings.social_facebook_link != blank or settings.social_twitter_link != blank -%}
        {%- assign has_social = true -%}
      {%- endif -%}

      {%- if has_social -%}
        <div class="wf-password__social">
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram" class="wf-password__social-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}
            <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener" aria-label="TikTok" class="wf-password__social-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.73a8.18 8.18 0 004.78 1.52V6.79a4.85 4.85 0 01-1.01-.1z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_twitter_link != blank -%}
            <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener" aria-label="X / Twitter" class="wf-password__social-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          {%- endif -%}
          {%- if settings.social_facebook_link != blank -%}
            <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook" class="wf-password__social-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

<style>
/* ══════════════════════════════════════════════════════
   PASSWORD PAGE — WF Urban Muscle
   Hereda: wf-split-screen, wf-split-image-panel,
           wf-split-overlay, wf-split-brand-text,
           wf-split-form-panel, wf-form-container,
           wf-form-header, wf-input-group, wf-btn-*
   ══════════════════════════════════════════════════════ */

/* Sin header: pantalla completa */
.wf-password-screen {
  min-height: 100vh;
}

/* Logo */
.wf-password__logo {
  margin-bottom: 0;
}
.wf-password__logo img {
  max-width: 140px;
  height: auto;
  display: block;
}
.wf-password__logo-text {
  font-size: 1.4rem;
  font-weight: 800;
  letter-spacing: 0.15em;
  color: #fff;
}

/* Encabezado: espacio entre logo y título */
.wf-password__header {
  margin-top: 2.5rem;
}

/* Etiqueta "Próximamente" — mismo estilo que novedades__label */
.wf-password__label {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #E22120;
  margin-bottom: 0.5rem;
}

/* Newsletter */
.wf-password__newsletter { margin-top: 0; }

.wf-password__success {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: #4ade80;
  font-size: 0.875rem;
  font-weight: 600;
  margin: 0.5rem 0 1.5rem;
}

/* Divisor */
.wf-password__divider {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin: 2rem 0;
}
.wf-password__divider::before,
.wf-password__divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(255,255,255,0.1);
}
.wf-password__divider span {
  flex-shrink: 0;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.2);
}

/* Formulario de contraseña */
.wf-password__form { margin-top: 0; }

/* Redes sociales */
.wf-password__social {
  display: flex;
  gap: 1rem;
  margin-top: 2.5rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(255,255,255,0.08);
}
.wf-password__social-link {
  color: rgba(255,255,255,0.35) !important;
  transition: color 0.2s;
  line-height: 1;
}
.wf-password__social-link:hover {
  color: #fff !important;
}

/* ── Light mode ── */
@media (prefers-color-scheme: light) {
  .wf-password__logo-text { color: #111; }
  .wf-password__divider::before,
  .wf-password__divider::after { background: rgba(0,0,0,0.1); }
  .wf-password__divider span { color: rgba(0,0,0,0.3); }
  .wf-password__social { border-top-color: rgba(0,0,0,0.08); }
  .wf-password__social-link { color: rgba(0,0,0,0.3) !important; }
  .wf-password__social-link:hover { color: #111 !important; }
}
</style>

{% schema %}
{
  "name": "Password — Próximamente",
  "settings": [
    {
      "type": "header",
      "content": "Panel izquierdo"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Imagen de fondo"
    },
    {
      "type": "text",
      "id": "brand_title",
      "label": "Título de marca",
      "default": "Urban Muscle"
    },
    {
      "type": "textarea",
      "id": "brand_subtitle",
      "label": "Frase de marca",
      "default": "Algo grande está por llegar."
    },
    {
      "type": "header",
      "content": "Panel derecho"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Etiqueta superior",
      "default": "Próximamente"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título principal",
      "default": "Estamos preparando algo increíble"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Vuelve pronto. Mientras tanto, déjanos tu email para ser el primero en enterarte."
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Etiqueta del campo email",
      "default": "Tu correo electrónico"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texto del botón",
      "default": "Avísame cuando abran"
    }
  ],
  "presets": [
    {
      "name": "Password — Próximamente",
      "category": "Password"
    }
  ]
}
{% endschema %}
